rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - companyName: string (required)
    //   - website: string (optional)
    //   - branding: map (required)
    //     - primaryColor: string
    //     - logoUrl: string (optional)
    //   - aiConfig: map (required)
    //     - toneOfVoice: string
    //     - companyBackground: string
    //   - updatedAt: timestamp (required)
    //
    // Collection: proposals
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required)
    //   - clientName: string (required)
    //   - clientEmail: string (optional)
    //   - value: number (optional)
    //   - status: string (required, enum: draft, sent, accepted, declined)
    //   - date: string (required)
    //   - content: string (required)
    //   - branding: map (required)
    //   - pricingItems: list (optional)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "pierrepress@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validators
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.companyName is string && data.companyName.size() > 0 && data.companyName.size() < 100 &&
             data.branding is map &&
             data.aiConfig is map &&
             data.updatedAt is timestamp &&
             (!('website' in data) || (data.website is string && data.website.size() < 200));
    }

    function isValidProposal(data) {
      return data.uid == request.auth.uid &&
             data.clientName is string && data.clientName.size() > 0 && data.clientName.size() < 100 &&
             data.status in ['draft', 'sent', 'accepted', 'declined'] &&
             data.date is string && data.date.size() < 50 &&
             data.content is string && data.content.size() < 50000 &&
             data.branding is map &&
             data.createdAt is timestamp &&
             (!('clientEmail' in data) || (data.clientEmail is string && data.clientEmail.size() < 100)) &&
             (!('value' in data) || (data.value is number)) &&
             (!('pricingItems' in data) || (data.pricingItems is list));
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /proposals/{proposalId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidProposal(request.resource.data);
      allow update: if isDocOwner() && isValidProposal(request.resource.data) &&
                      request.resource.data.createdAt == resource.data.createdAt &&
                      request.resource.data.uid == resource.data.uid;
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
