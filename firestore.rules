rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - Owner's user ID
    //   - companyName: string (required) - Name of the company
    //   - website: string (optional) - Website URL
    //   - branding: map (required) - { primaryColor: string, logoUrl: string }
    //   - aiConfig: map (required) - { toneOfVoice: string, companyBackground: string }
    //   - updatedAt: timestamp (required)
    //
    // Collection: proposals
    // Document ID: {proposalId}
    // Fields:
    //   - uid: string (required) - Owner's user ID
    //   - clientName: string (required) - Name of the client
    //   - clientEmail: string (optional) - Email of the client
    //   - value: number (optional) - Estimated contract value
    //   - status: string (required) - enum ["draft", "sent", "accepted", "declined"]
    //   - date: string (required) - Display date
    //   - content: string (required) - Markdown content
    //   - branding: map (required) - { primaryColor: string, logoUrl: string }
    //   - pricingItems: list (optional) - List of pricing items
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "pierrepress@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidProposal(data) {
      return data.uid is string && data.uid.size() > 0 &&
             data.clientName is string && data.clientName.size() > 0 && data.clientName.size() < 200 &&
             data.status in ['draft', 'sent', 'accepted', 'declined'] &&
             data.date is string &&
             data.content is string && data.content.size() < 50000 &&
             data.branding is map &&
             data.branding.primaryColor is string &&
             (!('value' in data) || data.value is number);
    }

    function isValidUser(data) {
      return data.uid is string && data.uid.size() > 0 &&
             data.companyName is string && data.companyName.size() > 0 && data.companyName.size() < 200 &&
             data.branding is map &&
             data.aiConfig is map;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /proposals/{proposalId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && isValidProposal(request.resource.data);
      allow update: if isDocOwner() && isValidProposal(request.resource.data) && request.resource.data.uid == resource.data.uid;
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
